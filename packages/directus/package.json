  "devDependencies": {
    "@types/node": "26.1.1",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "scripts": {
    "init": "tsx scripts/migrate.ts",
